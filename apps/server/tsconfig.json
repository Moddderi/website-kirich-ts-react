{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src", // Строго папка исходников самого сервера

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",

    "paths": {
      "@project/shared": ["../../packages/shared"] // Ссылка на корень пакета
    }
  },
  "include": ["src/**/*"], // Только исходники сервера
  "references": [
    { "path": "../../packages/shared" } // Связываем проекты
  ]
}
