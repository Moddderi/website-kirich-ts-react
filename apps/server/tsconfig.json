{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./", // <-- Компилируем относительно папки сервера

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",

    "paths": {
      "@project/shared": ["../../packages/shared/src"] // <-- Путь к исходникам shared
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*"] // <-- Захватываем файлы shared
}
